{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bun install)",
      "Bash(bun install:*)",
      "Bash(bun run dev:*)",
      "Bash(bun run build)",
      "Bash(bun run typecheck)",
      "Bash(bun test:*)",
      "Bash(bunx tsc --noEmit)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(npm install:*)",
      "Bash(pnpm install:*)",
      "Bash(yarn install:*)",
      "Bash(npm run:*)",
      "Bash(pnpm run:*)",
      "Bash(yarn:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Read(~/.config/ig-agent/**)",
      "Read(~/.local/share/ig-agent/**)",
      "Edit(~/.config/ig-agent/**)",
      "Edit(~/.local/share/ig-agent/**)",
      "Write(~/.config/ig-agent/**)",
      "Write(~/.local/share/ig-agent/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(bun.lock)",
      "Edit(LICENSE)"
    ]
  }
}
